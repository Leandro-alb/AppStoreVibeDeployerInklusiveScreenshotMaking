# Copy to .env (never commit .env)

# Required for screenshot capture
APP_BUNDLE_ID=com.example.myapp
APP_BUNDLE_PATH=/absolute/path/to/Build/Products/Debug-iphonesimulator/MyApp.app

# Screenshot runtime behavior
SCREENSHOT_MODE_ENV_KEY=WALKINATS_SCREENSHOT_MODE
SCREENSHOT_MODE_ENV_VALUE=1
SCREENSHOT_SCENE_ENV_KEY=WALKINATS_SCREENSHOT_SCENE
SCREENSHOT_DISABLE_FEATURE_ENV_KEY=WALKINATS_DISABLE_PTT
SCREENSHOT_DISABLE_FEATURE_ENV_VALUE=1
ASC_WAIT_SECONDS_DEFAULT=2
DELETE_CREATED_SIMULATORS=1
# Optional: pin runtime, e.g. com.apple.CoreSimulator.SimRuntime.iOS-18-2
SIM_RUNTIME_IDENTIFIER=

# Paths
# Relative paths are resolved from the scaffolded kit root.
SCREENSHOT_PLAN_PATH=config/screenshots.plan.json
SCREENSHOT_OUTPUT_DIR=artifacts/screenshots/raw

# Optional ASC upload
ASC_UPLOAD_SCREENSHOTS=0
ASC_PROFILE_NAME=walkiNATS
ASC_VERSION_LOCALIZATION_ID=
